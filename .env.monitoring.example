# Monitoring Configuration Example
# Copy this file to .env.monitoring and update the values

# Application Configuration
NODE_ENV=production
PORT=8000
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://commerce_user:commerce_password@localhost:5432/commerce_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Prometheus Configuration
PROMETHEUS_ENABLED=true
METRICS_PORT=8000
METRICS_PREFIX=commerce_

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_INSTALL_PLUGINS=grafana-piechart-panel,grafana-worldmap-panel

# AlertManager Configuration
ALERTMANAGER_WEB_EXTERNAL_URL=http://localhost:9093

# Email Notification Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@commerce-app.com

# Slack Notification Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL_CRITICAL=#alerts-critical
SLACK_CHANNEL_WARNING=#alerts-warning

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30000

# Business Metrics Configuration
BUSINESS_METRICS_ENABLED=true
INVENTORY_ALERT_THRESHOLD=10
CONVERSION_RATE_THRESHOLD=0.05
PAYMENT_FAILURE_THRESHOLD=0.05

# Security Monitoring
SECURITY_MONITORING_ENABLED=true
MAX_FAILED_LOGINS=5
UNUSUAL_ACTIVITY_THRESHOLD=5

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true
RESPONSE_TIME_THRESHOLD=0.1
ERROR_RATE_THRESHOLD=0.01

# Log Configuration
LOG_AGGREGATION_ENABLED=true
LOG_RETENTION_DAYS=30
ERROR_LOG_RETENTION_DAYS=90

# External Service Monitoring
BLACKBOX_MONITORING_ENABLED=true
EXTERNAL_HEALTH_CHECK_INTERVAL=30

# Retention Settings
PROMETHEUS_RETENTION=30d
GRAFANA_DATA_RETENTION=90d
LOKI_RETENTION=30d

# Storage Configuration
PROMETHEUS_STORAGE_SIZE=50Gi
GRAFANA_STORAGE_SIZE=10Gi
LOKI_STORAGE_SIZE=30Gi