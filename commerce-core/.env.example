# ==================================================
# Commerce Core - Environment Configuration Example
# ==================================================

# Node.js Environment
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
# Primary Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/commerce_core
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=commerce_core
DATABASE_USER=username
DATABASE_PASSWORD=password
DATABASE_SSL=false
DATABASE_CONNECTION_LIMIT=10
DATABASE_TIMEOUT=30000

# Secondary Database (MySQL - for analytics)
MYSQL_URL=mysql://username:password@localhost:3306/commerce_analytics
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=commerce_analytics
MYSQL_USER=username
MYSQL_PASSWORD=password

# MongoDB (for product catalogs and sessions)
MONGODB_URL=mongodb://localhost:27017/commerce_sessions
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=commerce_sessions

# Redis Configuration (Caching & Sessions)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=commerce:
REDIS_TTL=3600

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-change-this-in-production
BCRYPT_ROUNDS=12

# API Keys & External Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NAVER_MAPS_API_KEY=your-naver-maps-api-key
KAKAO_API_KEY=your-kakao-api-key

# Korean Payment Gateways
# KakaoPay
KAKAO_PAY_ADMIN_KEY=your-kakao-pay-admin-key
KAKAO_PAY_CID=your-kakao-pay-cid
KAKAO_PAY_SECRET=your-kakao-pay-secret

# NaverPay
NAVER_PAY_CLIENT_ID=your-naver-pay-client-id
NAVER_PAY_CLIENT_SECRET=your-naver-pay-client-secret
NAVER_PAY_MERCHANT_KEY=your-naver-pay-merchant-key

# TossPay
TOSS_PAY_CLIENT_KEY=your-toss-pay-client-key
TOSS_PAY_SECRET_KEY=your-toss-pay-secret-key

# NicePay
NICE_PAY_MID=your-nice-pay-mid
NICE_PAY_LICENSE_KEY=your-nice-pay-license-key
NICE_PAY_CANCEL_PASSWORD=your-nice-pay-cancel-password

# Bank Transfer
BANK_TRANSFER_API_KEY=your-bank-transfer-api-key
BANK_TRANSFER_SECRET=your-bank-transfer-secret

# File Storage & CDN
# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-s3-bucket-name

# Naver Cloud Platform Object Storage
NCP_ACCESS_KEY=your-ncp-access-key
NCP_SECRET_KEY=your-ncp-secret-key
NCP_REGION=KR
NCP_BUCKET=your-ncp-bucket-name

# CDN Configuration
CDN_URL=https://cdn.yourdomain.com
CDN_ENABLED=false

# Email Service (Korean providers)
# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your Commerce Site

# Naver Works (Korean email service)
NAVER_WORKS_EMAIL_ID=your-naver-works-id
NAVER_WORKS_EMAIL_PASSWORD=your-naver-works-password

# SMS Service (Korean providers)
# CoolSMS
COOLSMS_API_KEY=your-coolsms-api-key
COOLSMS_API_SECRET=your-coolsms-secret
COOLSMS_FROM_NUMBER=your-phone-number

# Aligo SMS
ALIGO_USER_ID=your-aligo-user-id
ALIGO_API_KEY=your-aligo-api-key
ALIGO_SENDER=your-sender-number

# Search & Analytics
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=password

# Google Analytics
GA_TRACKING_ID=your-ga-tracking-id
GA_MEASUREMENT_ID=your-ga4-measurement-id

# Korean Analytics Services
NAVER_ANALYTICS_ID=your-naver-analytics-id
WISETRACKER_ID=your-wisetracker-id

# Monitoring & Logging
# Sentry
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# New Relic
NEW_RELIC_LICENSE_KEY=your-newrelic-license
NEW_RELIC_APP_NAME=commerce-core

# Application Settings
APP_NAME=Commerce Core
APP_URL=http://localhost:3000
APP_VERSION=1.0.0
APP_DESCRIPTION=Korean E-commerce Core System

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Korean Locale Settings
DEFAULT_LOCALE=ko-KR
DEFAULT_TIMEZONE=Asia/Seoul
DEFAULT_CURRENCY=KRW

# Business Settings
TAX_RATE=0.1
SHIPPING_FREE_THRESHOLD=50000
RETURN_PERIOD_DAYS=7
REFUND_PERIOD_DAYS=14

# Development Tools
DEBUG=commerce:*
LOG_LEVEL=debug
ENABLE_SWAGGER=true
ENABLE_GRAPHQL_PLAYGROUND=true

# Testing
TEST_DATABASE_URL=postgresql://username:password@localhost:5432/commerce_core_test
TEST_REDIS_URL=redis://localhost:6379/1

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=5000

# Feature Flags
FEATURE_SOCIAL_LOGIN=true
FEATURE_WISHLIST=true
FEATURE_REVIEWS=true
FEATURE_RECOMMENDATIONS=true
FEATURE_INVENTORY_TRACKING=true
FEATURE_MULTI_LANGUAGE=false