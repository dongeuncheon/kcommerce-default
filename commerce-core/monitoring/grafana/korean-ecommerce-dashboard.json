{
  "dashboard": {
    "id": null,
    "title": "🇰🇷 Korean E-commerce Dashboard",
    "tags": ["korean", "ecommerce", "business"],
    "style": "dark",
    "timezone": "Asia/Seoul",
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {
      "timezone": "Asia/Seoul",
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "panels": [
      {
        "id": 1,
        "title": "🇰🇷 Korean Business Overview",
        "type": "stat",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m]))",
            "legendFormat": "총 요청/초",
            "refId": "A"
          },
          {
            "expr": "sum(rate(orders_completed_total[5m]))",
            "legendFormat": "주문 완료/초", 
            "refId": "B"
          },
          {
            "expr": "sum(payment_gateway_requests_total{gateway=~\"kakao_pay|naver_pay|toss_pay\"})",
            "legendFormat": "한국 결제 건수",
            "refId": "C"
          },
          {
            "expr": "sum(rate(mobile_app_sessions_total{market=\"korea\"}[5m]))",
            "legendFormat": "모바일 세션/초",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps",
            "min": 0
          }
        }
      },
      {
        "id": 2,
        "title": "Korean Business Hours Traffic Pattern",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum by (hour) (rate(http_requests_total[1h]))",
            "legendFormat": "시간별 트래픽",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "right"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 3,
        "title": "Korean Payment Gateways Health",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "up{job=\"korean-payment-gateways\", gateway=\"kakao_pay\"}",
            "legendFormat": "카카오페이",
            "refId": "A"
          },
          {
            "expr": "up{job=\"korean-payment-gateways\", gateway=\"naver_pay\"}",
            "legendFormat": "네이버페이",
            "refId": "B"
          },
          {
            "expr": "up{job=\"korean-payment-gateways\", gateway=\"toss_pay\"}",
            "legendFormat": "토스페이",
            "refId": "C"
          },
          {
            "expr": "up{job=\"korean-payment-gateways\", gateway=\"nice_pay\"}",
            "legendFormat": "나이스페이",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {"options": {"0": {"text": "DOWN"}}, "type": "value"},
              {"options": {"1": {"text": "UP"}}, "type": "value"}
            ]
          }
        }
      },
      {
        "id": 4,
        "title": "Korean E-commerce Conversion Funnel",
        "type": "barchart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(page_views_total{page=\"product\", market=\"korea\"}[5m]))",
            "legendFormat": "상품 조회",
            "refId": "A"
          },
          {
            "expr": "sum(rate(cart_created_total{market=\"korea\"}[5m]))",
            "legendFormat": "장바구니 추가",
            "refId": "B"
          },
          {
            "expr": "sum(rate(checkout_initiated_total{market=\"korea\"}[5m]))",
            "legendFormat": "결제 시작",
            "refId": "C"
          },
          {
            "expr": "sum(rate(orders_completed_total{market=\"korea\"}[5m]))",
            "legendFormat": "주문 완료",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        }
      },
      {
        "id": 5,
        "title": "Mobile vs Desktop Traffic (Korea)",
        "type": "piechart", 
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{device_type=\"mobile\", market=\"korea\"}[5m]))",
            "legendFormat": "모바일",
            "refId": "A"
          },
          {
            "expr": "sum(rate(http_requests_total{device_type=\"desktop\", market=\"korea\"}[5m]))",
            "legendFormat": "데스크톱",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        }
      },
      {
        "id": 6,
        "title": "Korean Payment Methods Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "sum(rate(payment_completed_total{gateway=\"kakao_pay\"}[5m]))",
            "legendFormat": "카카오페이",
            "refId": "A"
          },
          {
            "expr": "sum(rate(payment_completed_total{gateway=\"naver_pay\"}[5m]))",
            "legendFormat": "네이버페이",
            "refId": "B"
          },
          {
            "expr": "sum(rate(payment_completed_total{gateway=\"toss_pay\"}[5m]))",
            "legendFormat": "토스페이",
            "refId": "C"
          },
          {
            "expr": "sum(rate(payment_completed_total{gateway=\"card\"}[5m]))",
            "legendFormat": "신용카드",
            "refId": "D"
          },
          {
            "expr": "sum(rate(payment_completed_total{gateway=\"bank_transfer\"}[5m]))",
            "legendFormat": "계좌이체",
            "refId": "E"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        }
      },
      {
        "id": 7,
        "title": "System Performance Metrics",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "avg(cpu_usage_percent)",
            "legendFormat": "CPU 사용률 (%)",
            "refId": "A"
          },
          {
            "expr": "avg(memory_usage_percent)",
            "legendFormat": "메모리 사용률 (%)",
            "refId": "B"
          },
          {
            "expr": "avg(disk_usage_percent)",
            "legendFormat": "디스크 사용률 (%)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percent",
            "max": 100,
            "min": 0
          }
        }
      },
      {
        "id": 8,
        "title": "Korean Region Response Times",
        "type": "stat",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 32},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{region=\"seoul\"}[5m]))",
            "legendFormat": "서울 P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{region=\"seoul\"}[5m]))",
            "legendFormat": "서울 P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{region=\"busan\"}[5m]))",
            "legendFormat": "부산 P50",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{region=\"busan\"}[5m]))",
            "legendFormat": "부산 P95",
            "refId": "D"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Korean Business Hours Heatmap",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 38},
        "targets": [
          {
            "expr": "sum by (hour, day_of_week) (rate(http_requests_total[1h]))",
            "legendFormat": "{{hour}}시",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "spectrum"},
            "unit": "reqps"
          }
        },
        "options": {
          "calculate": false,
          "yAxis": {"unit": "short"},
          "tooltip": {"show": true}
        }
      },
      {
        "id": 10,
        "title": "Error Rate by Korean Payment Gateway",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 46},
        "targets": [
          {
            "expr": "rate(payment_gateway_errors_total{gateway=\"kakao_pay\"}[5m]) / rate(payment_gateway_requests_total{gateway=\"kakao_pay\"}[5m])",
            "legendFormat": "카카오페이 오류율",
            "refId": "A"
          },
          {
            "expr": "rate(payment_gateway_errors_total{gateway=\"naver_pay\"}[5m]) / rate(payment_gateway_requests_total{gateway=\"naver_pay\"}[5m])",
            "legendFormat": "네이버페이 오류율",
            "refId": "B"
          },
          {
            "expr": "rate(payment_gateway_errors_total{gateway=\"toss_pay\"}[5m]) / rate(payment_gateway_requests_total{gateway=\"toss_pay\"}[5m])",
            "legendFormat": "토스페이 오류율",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percentunit",
            "max": 0.1,
            "min": 0
          }
        }
      },
      {
        "id": 11,
        "title": "Korean Shipping Providers Status",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 46},
        "targets": [
          {
            "expr": "up{job=\"korean-shipping-metrics\", provider=\"korea_post\"}",
            "legendFormat": "우체국택배",
            "refId": "A"
          },
          {
            "expr": "up{job=\"korean-shipping-metrics\", provider=\"cj_logistics\"}",
            "legendFormat": "CJ대한통운",
            "refId": "B"
          },
          {
            "expr": "up{job=\"korean-shipping-metrics\", provider=\"hanjin\"}",
            "legendFormat": "한진택배",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {"options": {"0": {"text": "장애"}}, "type": "value"},
              {"options": {"1": {"text": "정상"}}, "type": "value"}
            ]
          }
        }
      },
      {
        "id": 12,
        "title": "Korean Customer Satisfaction Metrics",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 54},
        "targets": [
          {
            "expr": "avg(customer_satisfaction_score{market=\"korea\"})",
            "legendFormat": "고객 만족도",
            "refId": "A"
          },
          {
            "expr": "avg(nps_score{market=\"korea\"})",
            "legendFormat": "NPS 점수",
            "refId": "B"
          },
          {
            "expr": "(sum(rate(orders_completed_total{market=\"korea\"}[24h])) / sum(rate(cart_created_total{market=\"korea\"}[24h]))) * 100",
            "legendFormat": "전환율 (%)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 5},
                {"color": "green", "value": 8}
              ]
            },
            "max": 10,
            "min": 0
          }
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "name": "Korean Business Hours",
          "datasource": "prometheus",
          "enable": true,
          "expr": "korean_business_hours_start",
          "iconColor": "blue",
          "titleFormat": "업무 시작 (9시)"
        },
        {
          "name": "Korean Lunch Time",
          "datasource": "prometheus", 
          "enable": true,
          "expr": "korean_lunch_time_start",
          "iconColor": "orange",
          "titleFormat": "점심시간 (12시)"
        },
        {
          "name": "Korean Peak Shopping",
          "datasource": "prometheus",
          "enable": true,
          "expr": "korean_peak_shopping_start", 
          "iconColor": "red",
          "titleFormat": "쇼핑 피크 타임 (20시)"
        }
      ]
    },
    "variables": [
      {
        "name": "region",
        "type": "query",
        "query": "label_values(http_requests_total, region)",
        "current": {
          "value": "seoul",
          "text": "Seoul"
        },
        "options": [
          {"value": "seoul", "text": "서울"},
          {"value": "busan", "text": "부산"},
          {"value": "incheon", "text": "인천"},
          {"value": "daegu", "text": "대구"}
        ]
      },
      {
        "name": "payment_gateway",
        "type": "query", 
        "query": "label_values(payment_gateway_requests_total, gateway)",
        "current": {
          "value": "kakao_pay",
          "text": "KakaoPay"
        },
        "multi": true,
        "includeAll": true
      }
    ]
  }
}