# Test Environment Configuration
NODE_ENV=test
PORT=3001
HOST=localhost

# Database (Test database)
DATABASE_URL=postgresql://commerce_test:test_password@localhost:5432/commerce_core_test
DATABASE_SSL=false
DATABASE_CONNECTION_LIMIT=3

# Redis (Test database)
REDIS_URL=redis://localhost:6379/1
REDIS_KEY_PREFIX=commerce_test:

# Security (Test keys)
JWT_SECRET=test-jwt-secret-not-for-production
JWT_REFRESH_SECRET=test-refresh-secret-not-for-production
SESSION_SECRET=test-session-secret-not-for-production
BCRYPT_ROUNDS=4

# File Storage (Test/Mock)
AWS_REGION=ap-northeast-2
CDN_ENABLED=false

# Application
APP_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# Development Tools
DEBUG=
LOG_LEVEL=error
ENABLE_SWAGGER=false
ENABLE_GRAPHQL_PLAYGROUND=false

# Monitoring (Disabled for tests)
SENTRY_ENVIRONMENT=test

# Korean Settings
DEFAULT_LOCALE=ko-KR
DEFAULT_TIMEZONE=Asia/Seoul
DEFAULT_CURRENCY=KRW

# Business Settings (Test values)
TAX_RATE=0.1
SHIPPING_FREE_THRESHOLD=10000
RETURN_PERIOD_DAYS=1
REFUND_PERIOD_DAYS=1

# Rate Limiting (Disabled for tests)
RATE_LIMIT_WINDOW_MS=999999999
RATE_LIMIT_MAX_REQUESTS=999999

# Feature Flags (All enabled for testing)
FEATURE_SOCIAL_LOGIN=true
FEATURE_WISHLIST=true
FEATURE_REVIEWS=true
FEATURE_RECOMMENDATIONS=true
FEATURE_INVENTORY_TRACKING=true
FEATURE_MULTI_LANGUAGE=false

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_TIMEOUT=1000

# Test Settings
TEST_TIMEOUT=10000
TEST_PARALLEL=false